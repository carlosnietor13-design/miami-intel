# ============================================================
# MiamiIntel — Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel dashboard for production
# ============================================================

# Anthropic API Key (REQUIRED)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Site URL (for SEO metadata and OG images)
NEXT_PUBLIC_SITE_URL=https://miami-intel.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================================
# VERCEL DEPLOYMENT CHECKLIST
# ============================================================
# 1. Push this repo to GitHub
# 2. Import project in vercel.com/new
# 3. Set ANTHROPIC_API_KEY in Environment Variables
# 4. Set NEXT_PUBLIC_SITE_URL to your domain
# 5. Deploy — Vercel auto-detects Next.js
# ============================================================
